/**
 * Node: mediator engine and scripts.
 * Does not include Expo app screens or Supabase Edge Functions.
 */
{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "noEmit": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "types": [],
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": [
    "services/mediatorEngine/**/*.ts",
    "types/mediator/**/*.ts",
    "types/node-runtime.d.ts",
    "types/runtime-globals.d.ts",
    "services/*_test.ts",
    "scripts/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "supabase/**",
    "app/**",
    "components/**",
    "services/mediatorEngine/__tests__/architecture.runtime.test.ts",
    "services/ocrShared_test.ts"
  ]
}
