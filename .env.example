# Lokalny dev (supabase functions serve). NIE commituj .env.local.
# Plik ładowany lokalnie: supabase/functions/.env (patrz docs Supabase)

OPENAI_API_KEY=sk-proj-your-key-here

# ─── PRODUKCJA (Supabase chmura) ───────────────────────────────────────────
# WAŻNE: Vault ≠ Edge Function Secrets!
#
# ❌ NIE: Database → Vault / Integrations → Vault
# ✅ TAK: Project Settings → Edge Functions → Secrets
#    https://supabase.com/dashboard/project/ilqdxdjnabmbmmstvczh/settings/functions
#
# Nazwa secretu MUSI być dokładnie: OPENAI_API_KEY
#
# CLI (po supabase login):
#   npx supabase secrets set OPENAI_API_KEY=sk-proj-... --project-ref ilqdxdjnabmbmmstvczh
#   npx supabase secrets list --project-ref ilqdxdjnabmbmmstvczh
#
# Po ustawieniu secretu redeploy funkcji (wklejenie kodu w dashboardzie):
#   npx supabase functions deploy solo-coach --project-ref ilqdxdjnabmbmmstvczh
#
# Test:
#   bash scripts/check-solo-coach-edge.sh
