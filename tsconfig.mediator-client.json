/**
 * Production runtime client surface (Etap 2).
 * Uses supabase.stub.ts so this profile stays free of Expo/RN imports.
 * liveMediation implementation is checked under tsconfig.app.json / tsconfig.node.json.
 */
{
  "extends": "./tsconfig.node.json",
  "compilerOptions": {
    "paths": {
      "@/*": ["./*"],
      "@/services/supabase": ["./services/mediatorRuntimeClient/typecheck/supabase.stub.ts"]
    }
  },
  "include": [
    "services/liveMediation.types.ts",
    "services/mediatorRuntimeClient/**/*.ts",
    "types/mediator/**/*.ts",
    "types/runtime-globals.d.ts",
    "types/node-runtime.d.ts",
    "legacyMigration/**/*.ts",
    "hooks/useRuntimeSession.ts"
  ],
  "exclude": [
    "node_modules",
    "services/mediatorRuntimeClient/__tests__/**",
    "services/mediatorRuntimeClient/typecheck/**",
    "tests/**",
    "supabase/**",
    "app/**",
    "services/liveMediation.ts",
    "services/liveMediationI18n.ts"
  ]
}
